{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "server/**/*",
    "engine/*.ts",
    "shared/**/*"
  ],
  "exclude": [
    "app/**/*",
    "engine/__tests__/**/*",
    "node_modules",
    "dist"
  ]
}
